# ── Backend ─────────────────────────────────────────────────────
APP_ID=                   # Application ID (dev default: dev-app)
APP_SECRET=               # JWT session secret (dev has a built-in default)

# ── Database ────────────────────────────────────────────────────
# Use "dev" for local file storage (.data/dev-store.json, no MySQL)
# Or mysql://user:pass@host:port/dbname + npm run db:push
DATABASE_URL=dev

# ── Kimi OAuth (optional in local dev) ───────────────────────────
# If both URLs are set, Kimi sign-in is used. If omitted, use GET /api/dev/login
VITE_KIMI_AUTH_URL=       # e.g. https://auth.kimi.com
VITE_APP_ID=              # OAuth application ID (same as APP_ID)
KIMI_AUTH_URL=            # Same as VITE_KIMI_AUTH_URL (backend)
KIMI_OPEN_URL=            # e.g. https://open.kimi.com

# ── Admin ───────────────────────────────────────────────────────
OWNER_UNION_ID=           # Union ID for admin role on first login
